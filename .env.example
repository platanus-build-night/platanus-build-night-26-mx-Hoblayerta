# ── LLM (modelo-agnóstico; el proveedor por defecto es Anthropic) ──
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

# ── Lalamove (PRODUCCIÓN) ──
# Llaves de tu cuenta de developer Lalamove. La firma HMAC se calcula en cada
# request con el SECRET; el secret nunca se envía por la red.
LALAMOVE_API_KEY=pk_prod_xxxxxxxxxxxxxxxx
LALAMOVE_API_SECRET=sk_prod_xxxxxxxxxxxxxxxx
# Header "Market": código de país ISO. México = MX.
LALAMOVE_MARKET=MX
# Base de producción. Sandbox sería https://rest.sandbox.lalamove.com
LALAMOVE_BASE_URL=https://rest.lalamove.com
# Tipo de servicio por defecto (confírmalo con: npx tsx scripts/lalamove-cities.ts)
LALAMOVE_SERVICE_TYPE=MOTORCYCLE
LALAMOVE_LANGUAGE=es_MX
# Peso del paquete para la cotización (valor de catálogo de Lalamove).
LALAMOVE_WEIGHT=LESS_THAN_3KG
# Teléfono del remitente por defecto (10 dígitos) si no se pregunta.
LALAMOVE_SENDER_PHONE=5611234376

# ── Geocodificación (dirección → lat/lng) ──
# Por defecto usa Nominatim (OpenStreetMap), gratis y sin llave.
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
GEOCODE_COUNTRY=mx

# ── MPP (Machine Payments Protocol) — cobro en stablecoin sobre Tempo ──
# Solo se exige al CONFIRMAR (POST /order?confirm=true). Cotizar es gratis.
MPP_SECRET_KEY=               # secreto del server para firmar challenges (HMAC). Genera uno largo.
MPP_RECIPIENT_ADDRESS=0x...   # TU wallet EVM que RECIBE el pago.
MPP_CURRENCY_ADDRESS=0x20c0000000000000000000000000000000000000  # token TIP-20 (pathUSD). Cambia a USDC si tienes la dirección.
MPP_CURRENCY_DECIMALS=6       # decimales del token (TIP-20 = 6).
MPP_TESTNET=false             # false = Tempo mainnet (dinero real). "true" = Moderato (prueba).
USDC_PER_MXN=0.055            # tipo de cambio MXN→stablecoin para fijar el monto del cobro.

# ── Servidor HTTP (para exponerlo a internet / OpenClaw en la nube) ──
PORT=8787
# Clave para proteger POST /order. SIN esto el endpoint queda ABIERTO y
# cualquiera podría crear entregas reales con tu cuenta. Genera una larga y secreta.
API_KEY=pon-una-clave-larga-y-secreta-aqui
